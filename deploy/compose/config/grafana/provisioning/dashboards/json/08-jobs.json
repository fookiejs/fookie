      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 500 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "targets": [{ "format": "table", "rawSql": "SELECT count(*) AS value FROM outbox WHERE status='pending'", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "fookie-db" },
      "title": "Processing", "type": "stat", "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [{ "format": "table", "rawSql": "SELECT count(*) AS value FROM outbox WHERE status='processing'", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "fookie-db" },
