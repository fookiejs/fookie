      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT now() AS time, relname AS metric, n_tup_ins - n_tup_del AS value FROM pg_stat_user_tables ORDER BY value DESC LIMIT 15;",
          "refId": "A"
        }
      ]
    }
