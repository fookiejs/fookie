      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COALESCE((SELECT count(*) FROM outbox WHERE published_at IS NULL), 0) AS value;",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "fookie-db" },
      "title": "Tablo başına satır sayısı (top 20)",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "rows" }] },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT relname AS table, n_live_tup AS rows, pg_size_pretty(pg_total_relation_size(relid)) AS size FROM pg_stat_user_tables ORDER BY n_live_tup DESC LIMIT 20;",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "fookie-db" },
      "title": "Tablo boyutları (top 20)",
