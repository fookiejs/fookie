      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "continuous-BlPu" } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT relname AS metric, pg_total_relation_size(relid) AS value FROM pg_stat_user_tables ORDER BY pg_total_relation_size(relid) DESC LIMIT 20;",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "fookie-db" },
      "title": "Son 10 dk row growth (insert - delete)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
