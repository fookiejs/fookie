# Fookie environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Schema ──────────────────────────────────────────────────────────────────
# Host path to your .fql schema file — mounted read-only into the containers.
SCHEMA_FILE=./schema.fql

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty → bundled postgres service is used automatically.
# Set to point fookie at an external (cloud / managed) PostgreSQL:
#DB_URL=postgres://user:pass@your-db-host:5432/fookie?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
# Leave empty → bundled redis service is used automatically.
# Set to point fookie at an external Redis:
#REDIS_URL=redis://your-redis-host:6379

# ── Observability (auto-wired with --profile observability) ──────────────────
# Uncomment only if you have your own OTEL collector or Loki instance:
#OTLP_ENDPOINT=otel-collector:4318
#LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push

# ── Ports (change if conflicting with local services) ────────────────────────
FOOKIE_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# ── Admin key ────────────────────────────────────────────────────────────────
# Required for mutations guarded by requireAdminKey() in your schema.
FOOKEE_ADMIN_KEY=change_me_local_admin
