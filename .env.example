# Copy to .env for tools that read it, or set in your shell.
# Matches demo/docker-compose.yml postgres service.

FOOKIE_DATABASE_URL=postgres://fookie:fookie_dev@localhost:5432/fookie?sslmode=disable

# Demo / operator: must match GraphQL header X-Fookie-Admin-Key (or input.admin_key) for mutations guarded by requireAdminKey().
FOOKEE_ADMIN_KEY=change_me_local_admin
